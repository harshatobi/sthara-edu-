rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/superadmins/$(request.auth.uid));
    }

    // Checks /users first, then /global_users as fallback.
    // This is critical — teachers may be stored in either collection.
    function getUserData() {
      let uid = request.auth.uid;
      return exists(/databases/$(database)/documents/users/$(uid))
        ? get(/databases/$(database)/documents/users/$(uid)).data
        : get(/databases/$(database)/documents/global_users/$(uid)).data;
    }

    function getRole() {
      return getUserData().role;
    }

    function getUserSchoolId() {
      return getUserData().schoolId;
    }

    function isInSchool(schoolId) {
      return isAuthenticated() && getUserSchoolId() == schoolId;
    }


    function isAdminOrTeacherInSchool(schoolId) {
      return isInSchool(schoolId) && getRole() in ['admin', 'teacher'];
    }

    function isAdminInSchool(schoolId) {
      return isInSchool(schoolId) && getRole() == 'admin';
    }

    // ── /users (root — school-scoped, no cross-school reads) ──────────────────
    // FIXED: Previously `allow read: if isAuthenticated()` let any user from any
    // school read every other school's user records. Now scoped to own record
    // or superadmin only.
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSuperAdmin()
      );
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // ── /global_users ──────────────────────────────────────────────────────────
    match /global_users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSuperAdmin()
      );
      allow write: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSuperAdmin()
      );
    }

    // ── /student_chats ──────────────────────────────────────────────────────────
    match /student_chats/{studentId} {
      // Allow the student themselves OR any authenticated school user (teachers checking chats)
      // Use request.auth.uid directly — avoids calling getUserData() which fails for global_users students
      allow read, write: if request.auth != null && request.auth.uid == studentId;
      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == studentId;
      }
    }

    // ── /wellness_logs ──────────────────────────────────────────────────────────
    match /wellness_logs/{logId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && (
        getRole() in ['admin', 'teacher'] ||
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // ── /superadmins ───────────────────────────────────────────────────────────
    match /superadmins/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if false; // Only via Admin SDK / Firebase Console
    }

    // ── /schools ───────────────────────────────────────────────────────────────
    // Public read of school list is required for the login school-code lookup.
    // Only superadmins can create/delete schools; admins can update their own school.
    match /schools/{schoolId} {
      allow read: if true; // Needed for login school code lookup (unauthenticated)
      allow create: if isSuperAdmin() || (
        // Allow during onboarding — creating a new school document
        isAuthenticated()
      );
      allow update: if isSuperAdmin() || isAdminInSchool(schoolId);
      allow delete: if isSuperAdmin();

      // ── /schools/{id}/users ──────────────────────────────────────────────────
      match /users/{userId} {
        allow read: if isAuthenticated() && (
          request.auth.uid == userId ||
          isInSchool(schoolId) ||
          isSuperAdmin()
        );
        allow create: if isAuthenticated() && (
          request.auth.uid == userId ||
          isAdminInSchool(schoolId) ||
          isSuperAdmin()
        );
        allow update: if isAuthenticated() && (
          request.auth.uid == userId ||
          isAdminInSchool(schoolId) ||
          isSuperAdmin()
        );
        allow delete: if isAdminInSchool(schoolId) || isSuperAdmin();
      }

      // ── /schools/{id}/assignments ────────────────────────────────────────────
      match /assignments/{assignmentId} {
        allow read: if isAuthenticated() && (
          isInSchool(schoolId) ||
          isSuperAdmin()
        );
        allow create: if isAuthenticated() && (
          isAdminOrTeacherInSchool(schoolId) ||
          isSuperAdmin()
        );
        allow update: if isAuthenticated() && (
          isAdminOrTeacherInSchool(schoolId) ||
          isSuperAdmin()
        );
        allow delete: if isAdminOrTeacherInSchool(schoolId) || isSuperAdmin();

        // ── /submissions ───────────────────────────────────────────────────────
        match /submissions/{studentId} {
          allow read: if isAuthenticated() && (
            request.auth.uid == studentId ||
            isInSchool(schoolId) ||
            isSuperAdmin()
          );
          allow create: if isAuthenticated() && (
            request.auth.uid == studentId ||
            isSuperAdmin()
          );
          allow update: if isAuthenticated() && (
            request.auth.uid == studentId ||
            isAdminOrTeacherInSchool(schoolId) || // Teachers can write grades back
            isSuperAdmin()
          );
          allow delete: if isAdminOrTeacherInSchool(schoolId) || isSuperAdmin();
        }
      }

      // ── /schools/{id}/materials ──────────────────────────────────────────────
      match /materials/{materialId} {
        allow read: if isAuthenticated() && (
          isInSchool(schoolId) || isSuperAdmin()
        );
        allow write: if isAuthenticated() && (
          isAdminOrTeacherInSchool(schoolId) || isSuperAdmin()
        );
      }

      // ── /schools/{id}/notifications ──────────────────────────────────────────
      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && (
          isInSchool(schoolId) || isSuperAdmin()
        );
        allow write: if isAuthenticated() && (
          isAdminOrTeacherInSchool(schoolId) || isSuperAdmin()
        );
      }

      // ── /schools/{id}/situations (Situational Feed alerts) ───────────────────
      match /situations/{situationId} {
        allow read: if isAuthenticated() && (
          isInSchool(schoolId) || isSuperAdmin()
        );
        allow create: if isAuthenticated() && (
          isAdminOrTeacherInSchool(schoolId) || isSuperAdmin()
        );
        allow update: if isAuthenticated() && (
          isAdminOrTeacherInSchool(schoolId) || isSuperAdmin()
        );
        allow delete: if isAdminOrTeacherInSchool(schoolId) || isSuperAdmin();
      }
    }
  }
}
