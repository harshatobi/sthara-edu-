rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Function to check if user is a superadmin
    function isSuperAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/superadmins/$(request.auth.uid));
    }

    // Function to get the user's role
    function getRole() {
      return get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data.role;
    }

    // Function to get the user's schoolId
    function userSchoolId() {
      return get(/databases/$(database)/documents/global_users/$(request.auth.uid)).data.schoolId;
    }

    // global_users collection
    match /global_users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
    }

    // root users collection (where seed script creates data)
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
    }

    // superadmins collection
    match /superadmins/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if false; // Only manageable via Firebase Console or Admin SDK
    }

    // schools collection
    match /schools/{schoolId} {
      // Anyone can read school docs (needed for login check logic on the landing page)
      allow read: if true; 
      allow write: if isSuperAdmin();

      // users subcollection inside school
      match /users/{userId} {
        allow read: if isAuthenticated() && (
          request.auth.uid == userId || 
          isSuperAdmin() ||
          userSchoolId() == schoolId
        );
        
        allow write: if isAuthenticated() && (
          request.auth.uid == userId || 
          isSuperAdmin() ||
          (userSchoolId() == schoolId && getRole() == 'admin')
        );
      }

      // assignments subcollection inside school
      match /assignments/{assignmentId} {
        // Anyone in the school can read assignments
        allow read: if isAuthenticated() && (userSchoolId() == schoolId || isSuperAdmin());
        
        // Only teachers and admins can create/update assignments
        allow write: if isAuthenticated() && (
          isSuperAdmin() || 
          (userSchoolId() == schoolId && getRole() in ['teacher', 'admin'])
        );

        match /submissions/{studentId} {
          allow read: if isAuthenticated() && (
            request.auth.uid == studentId || 
            isSuperAdmin() ||
            userSchoolId() == schoolId
          );
          allow write: if isAuthenticated() && (
            request.auth.uid == studentId || 
            isSuperAdmin() ||
            (userSchoolId() == schoolId && getRole() in ['teacher', 'admin'])
          );
        }
      }

      // materials subcollection inside school
      match /materials/{materialId} {
        allow read: if isAuthenticated() && (userSchoolId() == schoolId || isSuperAdmin());
        allow write: if isAuthenticated() && (
          isSuperAdmin() || 
          (userSchoolId() == schoolId && getRole() in ['teacher', 'admin'])
        );
      }

      // notifications subcollection inside school
      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && (userSchoolId() == schoolId || isSuperAdmin());
        allow write: if isAuthenticated() && (
          isSuperAdmin() || 
          (userSchoolId() == schoolId && getRole() in ['teacher', 'admin'])
        );
      }
    }
  }
}
