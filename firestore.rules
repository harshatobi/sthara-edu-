rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/superadmins/$(request.auth.uid));
    }

    // Checks /users first, then /global_users as fallback.
    // CRITICAL: Teachers can be stored in EITHER collection.
    function getUserData() {
      let uid = request.auth.uid;
      return exists(/databases/$(database)/documents/users/$(uid))
        ? get(/databases/$(database)/documents/users/$(uid)).data
        : get(/databases/$(database)/documents/global_users/$(uid)).data;
    }

    function getRole() {
      return getUserData().role;
    }

    function getUserSchoolId() {
      return getUserData().schoolId;
    }

    function isInSchool(schoolId) {
      return isAuthenticated() && getUserSchoolId() == schoolId;
    }

    function isAdminOrTeacherInSchool(schoolId) {
      return isInSchool(schoolId) && getRole() in ['admin', 'teacher'];
    }

    function isAdminInSchool(schoolId) {
      return isInSchool(schoolId) && getRole() == 'admin';
    }

    // ── /users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Teachers need to LIST all students — allow any authenticated school member
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        isAuthenticated()
      );
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    // ── /global_users ──────────────────────────────────────────────────────────
    match /global_users/{userId} {
      // Teachers need to LIST all students — allow any authenticated user to read
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (
        request.auth.uid == userId ||
        isSuperAdmin()
      );
    }

    // ── /student_chats ──────────────────────────────────────────────────────────
    match /student_chats/{studentId} {
      allow read, write: if request.auth != null && request.auth.uid == studentId;
      match /messages/{messageId} {
        allow read, write: if request.auth != null && request.auth.uid == studentId;
      }
    }

    // ── /student_memory ────────────────────────────────────────────────────────
    match /student_memory/{studentId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == studentId ||
        isSuperAdmin()
      );
      allow write: if isAuthenticated() && (
        request.auth.uid == studentId ||
        isSuperAdmin()
      );
    }

    // ── /wellness_logs ──────────────────────────────────────────────────────────
    match /wellness_logs/{logId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isSuperAdmin();
    }

    // ── /superadmins ───────────────────────────────────────────────────────────
    match /superadmins/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if false;
    }

    // ── /schools ───────────────────────────────────────────────────────────────
    match /schools/{schoolId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isSuperAdmin() || isAdminInSchool(schoolId);
      allow delete: if isSuperAdmin();

      // /schools/{id}/users
      match /users/{userId} {
        allow read: if isAuthenticated() && (
          isInSchool(schoolId) || isSuperAdmin()
        );
        allow create, update: if isAuthenticated() && (
          isInSchool(schoolId) || isSuperAdmin()
        );
        allow delete: if isAdminInSchool(schoolId) || isSuperAdmin();
      }

      // /schools/{id}/assignments
      match /assignments/{assignmentId} {
        allow read: if isAuthenticated() && (
          isInSchool(schoolId) || isSuperAdmin()
        );
        allow create: if isAuthenticated() && (
          isAdminOrTeacherInSchool(schoolId) || isSuperAdmin()
        );
        allow update: if isAuthenticated() && (
          isAdminOrTeacherInSchool(schoolId) || isSuperAdmin()
        );
        allow delete: if isAdminOrTeacherInSchool(schoolId) || isSuperAdmin();

        // /submissions
        match /submissions/{studentId} {
          allow read: if isAuthenticated() && (
            request.auth.uid == studentId ||
            isInSchool(schoolId) ||
            isSuperAdmin()
          );
          allow create: if isAuthenticated() && (
            request.auth.uid == studentId || isSuperAdmin()
          );
          allow update: if isAuthenticated() && (
            request.auth.uid == studentId ||
            isAdminOrTeacherInSchool(schoolId) ||
            isSuperAdmin()
          );
          allow delete: if isAdminOrTeacherInSchool(schoolId) || isSuperAdmin();
        }
      }

      // /schools/{id}/syllabus
      match /syllabus/{moduleId} {
        allow read: if isAuthenticated() && (
          isInSchool(schoolId) || isSuperAdmin()
        );
        allow write: if isAuthenticated() && (
          isAdminOrTeacherInSchool(schoolId) || isSuperAdmin()
        );
      }

      // /schools/{id}/materials
      match /materials/{materialId} {
        allow read: if isAuthenticated() && (
          isInSchool(schoolId) || isSuperAdmin()
        );
        allow write: if isAuthenticated() && (
          isAdminOrTeacherInSchool(schoolId) || isSuperAdmin()
        );
      }

      // /schools/{id}/notifications
      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && (
          isInSchool(schoolId) || isSuperAdmin()
        );
        allow write: if isAuthenticated() && (
          isAdminOrTeacherInSchool(schoolId) || isSuperAdmin()
        );
      }

      // /schools/{id}/situations
      match /situations/{situationId} {
        allow read: if isAuthenticated() && (
          isInSchool(schoolId) || isSuperAdmin()
        );
        allow write: if isAuthenticated() && (
          isAdminOrTeacherInSchool(schoolId) || isSuperAdmin()
        );
      }
    }
  }
}
